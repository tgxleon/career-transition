# Required for all AI features (fit analysis, resume tailoring, cover letters,
# interview prep, thank-you / follow-up drafts, vibe check).
# Get a key at https://platform.claude.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: per-IP rate limit for AI calls (protects your API bill on a
# public deployment). Defaults: 15 requests per 60 minutes.
# AI_RATE_LIMIT=15
# AI_RATE_WINDOW_MINUTES=60

# Optional: which Claude model powers the AI features.
# Default: claude-opus-4-8 ($5/$25 per million tokens) — highest quality.
# Cheaper: claude-sonnet-5 ($3/$15, intro $2/$10) — near-Opus quality on
# resume/letter drafting at roughly 40-60% of the cost. Recommended once
# real users are burning through your credits.
# ANTHROPIC_MODEL=claude-sonnet-5
